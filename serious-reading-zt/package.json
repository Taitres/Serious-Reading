{
  "name": "serious-reading-zt",
  "version": "1.0.0",
  "description": "隐私小说阅读器 ZTools 插件 - 支持 TXT/EPUB/PDF，透明留窗伪装模式",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "publish": "ztools publish"
